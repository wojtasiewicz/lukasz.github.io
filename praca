function filterByClient(clientName) {
  switchTab('logs');
  setTimeout(() => {
    const sel = document.getElementById('filter-client');
    if (sel) {
      // find by text
      for (let i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === clientName) { sel.selectedIndex = i; break; }
      }
    }
    renderAllLogs();
  }, 50);
}

function populateClientFilterSelect() {
  const { clients, logs } = loadState();
  const sel = document.getElementById('filter-client');
  if (!sel) return;
  const currentVal = sel.value;
  // Build list: registered clients + unique clients from logs not in list
  const registeredNames = new Set(clients.map(c => c.name));
  const logClients = [...new Set(logs.map(l => l.client))].filter(n => !registeredNames.has(n));
  sel.innerHTML = '<option value="">🏢 Wszyscy klienci</option>';
  if (clients.length) {
    sel.innerHTML += `<optgroup label="── Zarejestrowane firmy ──">` +
      clients.map(c => `<option value="${c.name}">${c.name}</option>`).join('') +
      `</optgroup>`;
  }
  if (logClients.length) {
    sel.innerHTML += `<optgroup label="── Inni klienci (z wpisów) ──">` +
      logClients.map(n => `<option value="${n}">${n}</option>`).join('') +
      `</optgroup>`;
  }
  // Restore selection
  for (let i = 0; i < sel.options.length; i++) {
    if (sel.options[i].value === currentVal) { sel.selectedIndex = i; break; }
  }
}

function populateClientSelectForEmployee() {
  const { clients } = loadState();
