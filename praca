function openLogDetail(logId) {
  if (currentRole !== 'employer') return;
  const { logs } = loadState();
  const l = logs.find(x => x.id === logId);
  if (!l) return;

  const date = new Date(l.createdAt);
  const dateStr = date.toLocaleDateString('pl-PL', { weekday:'long', day:'2-digit', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit' });

  const resultClass = 'result-' + l.result;
  const resultLabel = resultLabels[l.result] || l.result;

  document.getElementById('detail-badges').innerHTML = `
    <span class="detail-badge emp-badge">👤 ${l.employeeName}</span>
    <span class="detail-badge ${resultClass}">${resultLabel}</span>
  `;
  document.getElementById('detail-client').textContent = '🏢 ' + l.client;
  document.getElementById('detail-topic').textContent = l.topic;
  document.getElementById('detail-date').textContent = '🕐 ' + dateStr;
  document.getElementById('detail-emp-name').textContent = l.employeeName;
  document.getElementById('detail-result').textContent = resultLabel;

  const notesSection = document.getElementById('detail-notes-section');
  if (l.notes) {
    notesSection.style.display = 'block';
    document.getElementById('detail-notes').textContent = l.notes;
  } else {
    notesSection.style.display = 'none';
  }

  const tagsSection = document.getElementById('detail-tags-section');
  if (l.tags && l.tags.length) {
    tagsSection.style.display = 'block';
    document.getElementById('detail-tags').innerHTML = l.tags.map(t => `<span class="detail-tag">${t}</span>`).join('');
  } else {
    tagsSection.style.display = 'none';
  }

  document.getElementById('log-detail-overlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeLogDetail(e) {
  if (e && e.target !== document.getElementById('log-detail-overlay')) return;
  document.getElementById('log-detail-overlay').style.display = 'none';
  document.body.style.overflow = '';
}

