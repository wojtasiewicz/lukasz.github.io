// ─────────────────────────────────────────────
//  CHAT SYSTEM
// ─────────────────────────────────────────────
function loadMessages() {
  const raw = localStorage.getItem('wl_messages');
  return raw ? JSON.parse(raw) : [];
}
function saveMessages(msgs) {
  localStorage.setItem('wl_messages', JSON.stringify(msgs));
}

// convId = employeeId (conversation is always between admin and one employee)
let activeChatConvId = null;

function getUnreadCount(convId, reader) {
  // reader = 'employer' or employeeId
  return loadMessages().filter(m => m.convId === convId && !m.readBy?.includes(reader)).length;
}

function getTotalUnread() {
  if (!currentRole) return 0;
  const msgs = loadMessages();
  if (currentRole === 'employer') {
    const convIds = [...new Set(msgs.map(m => m.convId))];
    return convIds.reduce((sum, cid) => sum + msgs.filter(m => m.convId === cid && !m.readBy?.includes('employer')).length, 0);
  } else {
    if (!currentUser?.id) return 0;
    return msgs.filter(m => m.convId === currentUser.id && !m.readBy?.includes(currentUser.id)).length;
  }
}

function updateUnreadBadge() {
  const count = getTotalUnread();
  const badge = document.getElementById('chat-unread-badge');
  const dropBadge = document.getElementById('dropdown-unread');
  if (badge) {
    badge.style.display = count > 0 ? 'block' : 'none';
    badge.textContent = count > 9 ? '9+' : count;
  }
  if (dropBadge) {
    dropBadge.style.display = count > 0 ? 'inline-block' : 'none';
    dropBadge.textContent = count > 9 ? '9+' : count;
  }
}

function markConvAsRead(convId) {
  const msgs = loadMessages();
  const reader = currentRole === 'employer' ? 'employer' : currentUser.id;
  msgs.forEach(m => {
    if (m.convId === convId) {
      if (!m.readBy) m.readBy = [];
      if (!m.readBy.includes(reader)) m.readBy.push(reader);
    }
  });
  saveMessages(msgs);
  updateUnreadBadge();
}

function openChatPanel() {
  const panel = document.getElementById('chat-panel');
  const backdrop = document.getElementById('chat-backdrop');
  panel.classList.add('open');
  backdrop.classList.add('open');

  if (currentRole === 'employer') {
    showConvList();
  } else {
    // Employee always chats with employer
    openConversation(currentUser.id);
  }
}

function closeChatPanel() {
  document.getElementById('chat-panel').classList.remove('open');
  document.getElementById('chat-backdrop').classList.remove('open');
  activeChatConvId = null;
}

function showConvList() {
  const { employees } = loadState();
  document.getElementById('chat-conv-list-view').style.display = 'flex';
  document.getElementById('chat-window-view').style.display = 'none';
  document.getElementById('chat-empty-view').style.display = 'none';

  const msgs = loadMessages();
  const list = document.getElementById('chat-conv-list');
  if (!employees.length) {
    list.innerHTML = `<div style="padding:2rem;text-align:center;color:var(--muted);font-size:0.78rem;">Brak pracowników do napisania.</div>`;
    return;
  }
  list.innerHTML = employees.map(emp => {
    const empMsgs = msgs.filter(m => m.convId === emp.id);
    const last = empMsgs[empMsgs.length - 1];
    const unread = empMsgs.filter(m => !m.readBy?.includes('employer')).length;
    const initials = emp.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
    const avatarKey = 'wl_avatar_' + emp.id;
    const avatarData = localStorage.getItem(avatarKey);
    const avatarHTML = avatarData ? `<img src="${avatarData}" />` : initials;
    const timeStr = last ? formatMsgTime(last.ts) : '';
    const preview = last ? (last.text.length > 28 ? last.text.slice(0,28)+'…' : last.text) : 'Brak wiadomości';
    return `
      <div class="chat-conv-item" onclick="openConversation('${emp.id}')">
        <div class="chat-conv-avatar">${avatarHTML}</div>
        <div class="chat-conv-info">
          <div class="chat-conv-name">${emp.name}</div>
          <div class="chat-conv-preview">${preview}</div>
        </div>
        <div class="chat-conv-meta">
          <div class="chat-conv-time">${timeStr}</div>
          ${unread > 0 ? `<div class="chat-conv-unread">${unread}</div>` : ''}
        </div>
      </div>
    `;
  }).join('');
}

function openConversation(empId) {
  const { employees } = loadState();
  activeChatConvId = empId;

  // Determine partner info
  let partnerName, partnerSub, avatarHTML;
  if (currentRole === 'employer') {
    const emp = employees.find(e => e.id === empId);
    if (!emp) return;
    partnerName = emp.name;
    partnerSub = emp.position;
    const ad = localStorage.getItem('wl_avatar_' + empId);
    const initials = emp.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
    avatarHTML = ad ? `<img src="${ad}" style="width:100%;height:100%;object-fit:cover;border-radius:10px;" />` : initials;
  } else {
    partnerName = 'Administrator';
    partnerSub = '👔 Pracodawca';
    const ad = localStorage.getItem('wl_avatar_admin');
    avatarHTML = ad ? `<img src="${ad}" style="width:100%;height:100%;object-fit:cover;border-radius:10px;" />` : '👔';
  }

  document.getElementById('chat-conv-list-view').style.display = 'none';
  document.getElementById('chat-window-view').style.display = 'flex';
  document.getElementById('chat-empty-view').style.display = 'none';

  document.getElementById('chat-window-name').textContent = partnerName;
  document.getElementById('chat-window-sub').textContent = partnerSub;
  document.getElementById('chat-window-avatar').innerHTML = avatarHTML;
  document.getElementById('chat-back-btn').style.display = currentRole === 'employer' ? 'block' : 'none';

  const sendBtn = document.getElementById('chat-send-btn');
  if (sendBtn) sendBtn.className = 'chat-send-btn' + (currentRole === 'employer' ? ' employer' : '');

  markConvAsRead(empId);
  renderMessages(empId);
}

function backToConvList() {
  activeChatConvId = null;
  showConvList();
}

function renderMessages(convId) {
  const msgs = loadMessages().filter(m => m.convId === convId);
  const container = document.getElementById('chat-messages');

  if (!msgs.length) {
    container.innerHTML = `<div style="text-align:center;color:var(--muted);font-size:0.75rem;padding:2rem;">Brak wiadomości. Napisz pierwszy!</div>`;
    return;
  }

  let html = '';
  let lastDate = '';
  msgs.forEach(msg => {
    const d = new Date(msg.ts);
    const dateLabel = d.toLocaleDateString('pl-PL', { day:'2-digit', month:'long' });
    if (dateLabel !== lastDate) {
      html += `<div class="chat-date-sep"><span>${dateLabel}</span></div>`;
      lastDate = dateLabel;
    }
    const isSent = (currentRole === 'employer' && msg.sender === 'employer') ||
                   (currentRole === 'employee' && msg.sender === currentUser.id);
    const timeStr = d.toLocaleTimeString('pl-PL', { hour:'2-digit', minute:'2-digit' });
    html += `<div class="chat-msg ${isSent ? 'sent' : 'received'}${msg.sender === 'employer' ? ' employer-msg' : ''}">
      ${escapeHtml(msg.text)}
      <span class="chat-msg-time">${timeStr}</span>
    </div>`;
  });
  container.innerHTML = html;
  container.scrollTop = container.scrollHeight;
}

function sendMessage() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text || !activeChatConvId) return;

  const msgs = loadMessages();
  const senderId = currentRole === 'employer' ? 'employer' : currentUser.id;
  msgs.push({
    id: 'msg_' + Date.now(),
    convId: activeChatConvId,
    sender: senderId,
    text,
    ts: new Date().toISOString(),
    readBy: [senderId]
  });
  saveMessages(msgs);
  input.value = '';
  input.style.height = 'auto';
  renderMessages(activeChatConvId);
  updateUnreadBadge();
  // Refresh conv list in background
  if (currentRole === 'employer') {
    // don't switch away from chat window
  }
}

function chatInputKeydown(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function autoResizeChatInput(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function formatMsgTime(ts) {
  const d = new Date(ts);
  const now = new Date();
  const diff = now - d;
  if (diff < 60000) return 'teraz';
  if (diff < 3600000) return Math.floor(diff/60000) + ' min';
  if (d.toDateString() === now.toDateString()) return d.toLocaleTimeString('pl-PL', {hour:'2-digit',minute:'2-digit'});
  return d.toLocaleDateString('pl-PL', {day:'2-digit',month:'2-digit'});
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
}

// Poll for new messages every 3 seconds when chat is open
setInterval(() => {
  if (!currentRole) return;
  if (activeChatConvId) {
    markConvAsRead(activeChatConvId);
    renderMessages(activeChatConvId);
  }
  updateUnreadBadge();
  if (currentRole === 'employer' && document.getElementById('chat-conv-list-view')?.style.display !== 'none') {
    showConvList();
  }
}, 3000);

// ─────────────────────────────────────────────
//  AVATAR MANAGEMENT
// ─────────────────────────────────────────────
function getAvatarKey() {
  if (currentRole === 'employer') return 'wl_avatar_admin';
  return 'wl_avatar_' + currentUser.id;
}

function handleAvatarUpload(who, input) {
  const file = input.files[0];
  if (!file) return;
  if (file.size > 2 * 1024 * 1024) { toast('Plik jest za duży (maks. 2MB)', 'error'); return; }
  const reader = new FileReader();
  reader.onload = function(e) {
    const dataUrl = e.target.result;
    const key = who === 'admin' ? 'wl_avatar_admin' : 'wl_avatar_' + currentUser.id;
    localStorage.setItem(key, dataUrl);
    loadAvatarPreview(who);
    updateTopbarAvatar();
    if (who === 'employee') renderEmployees_safe();
    toast('Zdjęcie profilowe zaktualizowane!');
  };
  reader.readAsDataURL(file);
}

function removeAvatar(who) {
  const key = who === 'admin' ? 'wl_avatar_admin' : 'wl_avatar_' + currentUser.id;
  localStorage.removeItem(key);
  loadAvatarPreview(who);
  updateTopbarAvatar();
  if (who === 'employee') renderEmployees_safe();
  toast('Zdjęcie usunięte');
}

function loadAvatarPreview(who) {
  const key = who === 'admin' ? 'wl_avatar_admin' : 'wl_avatar_' + currentUser.id;
  const previewId = who === 'admin' ? 'admin-avatar-preview' : 'emp-avatar-preview';
  const el = document.getElementById(previewId);
  if (!el) return;
  const data = localStorage.getItem(key);
  if (data) {
    el.innerHTML = `<img src="${data}" alt="Avatar" />`;
  } else {
    el.innerHTML = who === 'admin' ? '👔' : '💼';
  }
}

function updateTopbarAvatar() {
  const wrap = document.getElementById('topbar-avatar-wrap');
  if (!wrap) return;
  const key = currentRole === 'employer' ? 'wl_avatar_admin' : 'wl_avatar_' + (currentUser?.id || '');
  const data = localStorage.getItem(key);
  if (data) {
    wrap.innerHTML = `<img src="${data}" alt="Avatar" class="topbar-avatar" />`;
  } else {
    const initials = currentRole === 'employer'
      ? 'A'
      : (currentUser?.name || '?').split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
    const bg = currentRole === 'employer' ? 'var(--accent)' : 'var(--employee)';
    wrap.innerHTML = `<div class="topbar-avatar-placeholder" style="background:${bg};color:#fff;">${initials}</div>`;
  }
  updateDropdownInfo();
}

// Safe re-render of employees only if on that tab
function renderEmployees_safe() {
  const el = document.getElementById('employees-grid');
  if (el && document.getElementById('tab-employees').style.display !== 'none') {
    renderEmployees();
  }
}

// ─────────────────────────────────────────────
//  CHANGE ADMIN LOGIN
// ─────────────────────────────────────────────
function changeAdminLogin() {
  const newLogin = document.getElementById('admin-new-login').value.trim();
  if (newLogin.length < 3) { toast('Login musi mieć min. 3 znaki', 'error'); return; }
  localStorage.setItem('wl_admin_login', newLogin);
  const displayEl = document.getElementById('admin-current-login-display');
  if (displayEl) displayEl.value = newLogin;
  document.getElementById('admin-new-login').value = '';
  toast('Login administratora zmieniony!');
}

// ─────────────────────────────────────────────
//  FORGOT CREDENTIALS (on login screen)
// ─────────────────────────────────────────────
function showForgotCredentials() {
  document.getElementById('forgot-new-login').value = '';
  document.getElementById('forgot-new-pass').value = '';
  document.getElementById('forgot-new-pass2').value = '';
  document.getElementById('forgot-modal').style.display = 'flex';
}

function closeForgotModal() {
  document.getElementById('forgot-modal').style.display = 'none';
}

function confirmForgotCredentials() {
  const newLogin = document.getElementById('forgot-new-login').value.trim();
  const newPass  = document.getElementById('forgot-new-pass').value;
  const newPass2 = document.getElementById('forgot-new-pass2').value;

  let changed = false;

  if (newLogin) {
    if (newLogin.length < 3) { toast('Login musi mieć min. 3 znaki', 'error'); return; }
    localStorage.setItem('wl_admin_login', newLogin);
    changed = true;
  }

  if (newPass) {
    if (newPass.length < 4) { toast('Hasło musi mieć min. 4 znaki', 'error'); return; }
    if (newPass !== newPass2) { toast('Hasła nie są identyczne', 'error'); return; }
    localStorage.setItem('wl_admin_pass', newPass);
    changed = true;
  }

  if (!changed) { toast('Nic nie wpisałeś — brak zmian', 'error'); return; }

  closeForgotModal();
  // Show updated login hint
  if (newLogin) document.getElementById('emp-login').value = newLogin;
  toast('Dane logowania zaktualizowane!');
}

// ─────────────────────────────────────────────
//  PASSWORD MANAGEMENT
// ─────────────────────────────────────────────

// Toggle show/hide for any password input
function togglePass(inputId, btn) {
  const input = document.getElementById(inputId);
  if (!input) return;
  if (input.type === 'password') {
    input.type = 'text';
    btn.textContent = '🙈';
  } else {
    input.type = 'password';
    btn.textContent = '👁';
  }
}

// Toggle employee password visibility on employee card
function toggleEmpPass(empId, plainPass, btn) {
  const el = document.getElementById('pass-val-' + empId);
  if (!el) return;
  if (el.dataset.shown === '1') {
    el.textContent = '•'.repeat(plainPass.length);
    el.dataset.shown = '0';
    btn.textContent = '👁';
  } else {
    el.textContent = plainPass;
    el.dataset.shown = '1';
    btn.textContent = '🙈';
  }
}

// Admin resets employee password directly
function showResetEmpPass(empId) {
  const { employees } = loadState();
  const emp = employees.find(e => e.id === empId);
  if (!emp) return;
  document.getElementById('reset-emp-id').value = empId;
  document.getElementById('reset-emp-label').textContent = `Nowe hasło dla: ${emp.name}`;
  document.getElementById('reset-emp-new-pass').value = '';
  document.getElementById('reset-emp-new-pass').type = 'password';
  document.getElementById('reset-pass-modal').style.display = 'flex';
}

function closeResetPassModal() {
  document.getElementById('reset-pass-modal').style.display = 'none';
}

function confirmResetEmpPass() {
  const empId = document.getElementById('reset-emp-id').value;
  const newPass = document.getElementById('reset-emp-new-pass').value;
  if (newPass.length < 4) { toast('Hasło musi mieć min. 4 znaki', 'error'); return; }
  const { employees } = loadState();
  const idx = employees.findIndex(e => e.id === empId);
  if (idx === -1) return;
  employees[idx].password = newPass;
  // If this employee is currently logged in, update currentUser
  if (currentRole === 'employee' && currentUser.id === empId) {
    currentUser.password = newPass;
  }
  saveEmployees(employees);
  closeResetPassModal();
  renderEmployees();
  toast(`Hasło pracownika zmienione!`);
}

// Change admin password - no old password required
function changeAdminPassword() {
  const newPass = document.getElementById('admin-new-pass').value;
  const newPass2 = document.getElementById('admin-new-pass2').value;
  if (newPass.length < 4) { toast('Nowe hasło musi mieć min. 4 znaki', 'error'); return; }
  if (newPass !== newPass2) { toast('Hasła nie są identyczne', 'error'); return; }
  localStorage.setItem('wl_admin_pass', newPass);
  document.getElementById('admin-new-pass').value = '';
  document.getElementById('admin-new-pass2').value = '';
  toast('Hasło administratora zmienione!');
}

// Change employee own password
function changeEmployeePassword() {
  const oldPass = document.getElementById('emp-old-pass').value;
  const newPass = document.getElementById('emp-new-pass').value;
  const newPass2 = document.getElementById('emp-new-pass2').value;
  if (oldPass !== currentUser.password) { toast('Aktualne hasło jest nieprawidłowe', 'error'); return; }
  if (newPass.length < 4) { toast('Nowe hasło musi mieć min. 4 znaki', 'error'); return; }
  if (newPass !== newPass2) { toast('Hasła nie są identyczne', 'error'); return; }
  const { employees } = loadState();
  const idx = employees.findIndex(e => e.id === currentUser.id);
  if (idx === -1) return;
  employees[idx].password = newPass;
  currentUser.password = newPass;
  saveEmployees(employees);
  document.getElementById('emp-old-pass').value = '';
  document.getElementById('emp-new-pass').value = '';
  document.getElementById('emp-new-pass2').value = '';
  toast('Hasło zmienione pomyślnie!');
}

// ─────────────────────────────────────────────
//  TOAST
// ─────────────────────────────────────────────
function toast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = type === 'error' ? 'var(--danger)' : 'var(--success)';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

