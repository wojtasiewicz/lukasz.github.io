function populateFilterSelect() {
  const { employees } = loadState();
  const sel = document.getElementById('filter-emp');
  if (!sel) return;
  const currentVal = sel.value;
  sel.innerHTML = '<option value="">👥 Wszyscy pracownicy</option>';
  employees.forEach(e => {
    sel.innerHTML += `<option value="${e.id}">${e.name}</option>`;
  });
  for (let i = 0; i < sel.options.length; i++) {
    if (sel.options[i].value === currentVal) { sel.selectedIndex = i; break; }
  }
}

function clearFilters() {
  document.getElementById('filter-search').value = '';
  document.getElementById('filter-emp').value = '';
  document.getElementById('filter-client').value = '';
  renderAllLogs();
}

function renderAllLogs() {
  const { logs, employees } = loadState();
  const search = (document.getElementById('filter-search')?.value || '').toLowerCase().trim();
  const empFilter = document.getElementById('filter-emp')?.value || '';
  const clientFilter = document.getElementById('filter-client')?.value || '';

  let filtered = [...logs]; // already newest first (unshift on add)
  if (empFilter) filtered = filtered.filter(l => l.employeeId === empFilter);
  if (clientFilter) filtered = filtered.filter(l => l.client === clientFilter);
  if (search) filtered = filtered.filter(l =>
    l.topic.toLowerCase().includes(search) ||
    (l.notes || '').toLowerCase().includes(search) ||
    l.client.toLowerCase().includes(search)
  );

  // Update count
  const countEl = document.getElementById('logs-count');
  if (countEl) countEl.textContent = `(${filtered.length})`;

  // Active filter chips
  const chipsEl = document.getElementById('active-filters');
  if (chipsEl) {
    const chips = [];
    if (empFilter) {
      const emp = employees.find(e => e.id === empFilter);
      if (emp) chips.push(`<span class="filter-chip">👤 ${emp.name}</span>`);
    }
    if (clientFilter) chips.push(`<span class="filter-chip">🏢 ${clientFilter}</span>`);
    if (search) chips.push(`<span class="filter-chip">🔍 "${search}"</span>`);
    chipsEl.innerHTML = chips.join('');
  }

  const container = document.getElementById('all-logs');
  if (!filtered.length) {
    container.innerHTML = `<div class="empty"><div class="empty-icon">🔍</div><h3>Brak wyników</h3><p>Nie znaleziono wpisów pasujących do wybranych filtrów.</p></div>`;
    return;
  }
  container.innerHTML = filtered.map(l => logHTML(l)).join('');
}

function renderOverview() {
  const { employees, logs } = loadState();
  const today = new Date().toDateString();
  const todayLogs = logs.filter(l => new Date(l.createdAt).toDateString() === today);
  const positive = logs.filter(l => l.result === 'pozytywny').length;

  document.getElementById('overview-stats').innerHTML = `
    <div class="stat-card"><div class="big-num">${logs.length}</div><p>Wszystkich wpisów</p></div>
    <div class="stat-card"><div class="big-num emp">${employees.length}</div><p>Pracowników</p></div>
    <div class="stat-card"><div class="big-num">${todayLogs.length}</div><p>Wpisów dzisiaj</p></div>
    <div class="stat-card"><div class="big-num green">${positive}</div><p>Pozytywnych rozmów</p></div>
  `;

  const recentLogs = logs.slice(0, 5);
  const container = document.getElementById('overview-logs');
  if (!recentLogs.length) {
    container.innerHTML = `<div class="empty"><div class="empty-icon">📭</div><h3>Brak wpisów</h3><p>Pracownicy jeszcze nie dodali żadnych rozmów.</p></div>`;
    return;
  }
  container.innerHTML = recentLogs.map(l => logHTML(l)).join('');
}

