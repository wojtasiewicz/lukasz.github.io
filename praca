// ─────────────────────────────────────────────
const resultLabels = {
  pozytywny: '✅ Pozytywny',
  neutralny: '⚪ Neutralny',
  negatywny: '❌ Negatywny',
  'do-kontaktu': '📞 Do kontaktu'
};

function logHTML(l) {
  const date = new Date(l.createdAt);
  const dateStr = date.toLocaleDateString('pl-PL', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
  const tags = l.tags?.length ? l.tags.map(t => `<span class="tag">${t}</span>`).join('') : '';
  const clickable = currentRole === 'employer' ? `onclick="openLogDetail('${l.id}')"` : '';
  const hint = currentRole === 'employer' ? `<div class="log-entry-hint">👁 Kliknij aby zobaczyć szczegóły</div>` : '';
  return `
    <div class="log-entry" ${clickable}>
      <div class="log-header">
        <div class="log-meta">
          <span class="log-emp">👤 ${l.employeeName}</span>
          <span class="log-client">${l.client}</span>
          <span class="tag">${resultLabels[l.result] || l.result}</span>
        </div>
        <span class="log-date">${dateStr}</span>
      </div>
      <div class="log-topic">${l.topic}</div>
      ${l.notes ? `<div class="log-notes">${l.notes.length > 120 ? l.notes.slice(0,120) + '...' : l.notes}</div>` : ''}
      ${tags ? `<div class="log-tags">${tags}</div>` : ''}
      ${hint}
    </div>
  `;
}

