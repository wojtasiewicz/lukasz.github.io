<script>
// ─────────────────────────────────────────────
//  STATE
// ─────────────────────────────────────────────
let currentRole = null;
let currentUser = null;

// Load state from localStorage
function loadState() {
  const emp = localStorage.getItem('wl_employees');
  const logs = localStorage.getItem('wl_logs');
  const clients = localStorage.getItem('wl_clients');
  return {
    employees: emp ? JSON.parse(emp) : [],
    logs: logs ? JSON.parse(logs) : [],
    clients: clients ? JSON.parse(clients) : []
  };
}

function saveEmployees(employees) {
  localStorage.setItem('wl_employees', JSON.stringify(employees));
}

function saveLogs(logs) {
  localStorage.setItem('wl_logs', JSON.stringify(logs));
}

function saveClients(clients) {
  localStorage.setItem('wl_clients', JSON.stringify(clients));
}

// Employer credentials
const EMPLOYER_LOGIN = 'admin';
const EMPLOYER_PASS = 'admin123';

// ─────────────────────────────────────────────
//  LOGIN
// ─────────────────────────────────────────────
function showLogin(role) {
  document.getElementById('role-select').style.display = 'none';
  if (role === 'employer') {
    document.getElementById('employer-login').style.display = 'block';
  } else {
    populateEmployeeSelect();
    document.getElementById('employee-login').style.display = 'block';
  }
}

function showRoleSelect() {
  document.getElementById('role-select').style.display = 'grid';
  document.getElementById('employer-login').style.display = 'none';
  document.getElementById('employee-login').style.display = 'none';
  document.getElementById('emp-err').style.display = 'none';
  document.getElementById('emp-worker-err').style.display = 'none';
}

function populateEmployeeSelect() {
  const { employees } = loadState();
  const sel = document.getElementById('emp-select');
  sel.innerHTML = '<option value="">-- wybierz --</option>';
  employees.forEach(e => {
    sel.innerHTML += `<option value="${e.id}">${e.name} — ${e.position}</option>`;
  });
}

function loginEmployer() {
  const login = document.getElementById('emp-login').value.trim();
  const pass = document.getElementById('emp-pass').value;
  const err = document.getElementById('emp-err');
  const storedPass = localStorage.getItem('wl_admin_pass') || 'admin123';
  const storedLogin = localStorage.getItem('wl_admin_login') || EMPLOYER_LOGIN;
  if (login === storedLogin && pass === storedPass) {
    err.style.display = 'none';
    currentRole = 'employer';
    currentUser = { name: 'Administrator', role: 'employer' };
    enterApp();
  } else {
    err.style.display = 'block';
  }
}

function loginEmployee() {
  const id = document.getElementById('emp-select').value;
  const pass = document.getElementById('emp-worker-pass').value;
  const err = document.getElementById('emp-worker-err');
  const { employees } = loadState();
  const emp = employees.find(e => e.id === id);
  if (emp && emp.password === pass) {
    err.style.display = 'none';
    currentRole = 'employee';
    currentUser = emp;
    enterApp();
  } else {
    err.style.display = 'block';
  }
}

function enterApp() {
  document.getElementById('login-screen').style.display = 'none';
  const app = document.getElementById('app-screen');
  app.style.display = 'flex';

  document.getElementById('topbar-name').textContent = currentUser.name;
  updateTopbarAvatar();
  updateDropdownInfo();
  updateUnreadBadge();

  if (currentRole === 'employer') {
    document.getElementById('employer-view').style.display = 'block';
    document.getElementById('employee-view').style.display = 'none';
    renderOverview();
    renderEmployees();
    renderClients();
    renderAllLogs();
    populateFilterSelect();
    populateClientFilterSelect();
    // populate current login field
    setTimeout(() => {
      const loginEl = document.getElementById('admin-current-login-display');
      if (loginEl) loginEl.value = localStorage.getItem('wl_admin_login') || EMPLOYER_LOGIN;
      loadAvatarPreview('admin');
