<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WorkLog CRM</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --card: #18181f;
    --border: #2a2a38;
    --accent: #ff6b35;
    --accent2: #7c3aed;
    --text: #f0f0ff;
    --muted: #8888aa;
    --success: #22c55e;
    --danger: #ef4444;
    --employer: #ff6b35;
    --employee: #7c3aed;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Mono', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 999;
  }

  /* ── LOGIN SCREEN ── */
  #login-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
    animation: fadeIn 0.6s ease;
  }

  .login-logo {
    font-family: 'Syne', sans-serif;
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -2px;
    margin-bottom: 0.3rem;
  }
  .login-logo span { color: var(--accent); }

  .login-sub {
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 3rem;
  }

  .role-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 560px;
    width: 100%;
  }

  .role-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .role-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(255,107,53,0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .role-card.employee::before {
    background: radial-gradient(circle at center, rgba(124,58,237,0.1) 0%, transparent 60%);
  }
  .role-card:hover { border-color: var(--accent); transform: translateY(-4px); }
  .role-card:hover::before { opacity: 1; }
  .role-card.employee:hover { border-color: var(--employee); }

  .role-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .role-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .role-desc { color: var(--muted); font-size: 0.72rem; line-height: 1.5; }

  /* ── LOGIN FORM ── */
  .login-form {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem;
    max-width: 420px;
    width: 100%;
    animation: slideUp 0.4s ease;
  }

  .form-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .form-subtitle { color: var(--muted); font-size: 0.75rem; margin-bottom: 2rem; }

  .field { margin-bottom: 1.2rem; }
  .field label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .field input, .field select, .field textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.8rem 1rem;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    transition: border-color 0.2s;
    outline: none;
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    border-color: var(--accent);
  }
  .field textarea { resize: vertical; min-height: 90px; }
  .field select option { background: var(--surface); }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.6rem;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-family: 'DM Mono', monospace;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: all 0.2s ease;
  }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: #ff8055; transform: translateY(-1px); }
  .btn-secondary { background: var(--employee); color: #fff; }
  .btn-secondary:hover { background: #9d5df0; transform: translateY(-1px); }
  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { border-color: var(--muted); color: var(--text); }
  .btn-danger { background: var(--danger); color: #fff; }
  .btn-danger:hover { opacity: 0.85; }
  .btn-sm { padding: 0.4rem 0.9rem; font-size: 0.72rem; }
  .btn-full { width: 100%; justify-content: center; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .back-link {
    color: var(--muted);
    font-size: 0.72rem;
    cursor: pointer;
    margin-top: 1.2rem;
    text-align: center;
    transition: color 0.2s;
    display: block;
  }
  .back-link:hover { color: var(--text); }

  /* ── APP LAYOUT ── */
  #app-screen { display: none; min-height: 100vh; flex-direction: column; }

  .topbar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .topbar-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -1px;
  }
  .topbar-logo span { color: var(--accent); }

  .topbar-right { display: flex; align-items: center; gap: 1rem; }

  .user-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
  }
  .user-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
  .user-dot.emp { background: var(--employee); }

  .main-content {
    flex: 1;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── TABS ── */
  .tabs {
    display: flex;
    gap: 0.3rem;
    background: var(--surface);
    border-radius: 12px;
    padding: 0.3rem;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
    width: fit-content;
  }
  .tab {
    padding: 0.5rem 1.2rem;
    border-radius: 9px;
    cursor: pointer;
    font-size: 0.78rem;
    color: var(--muted);
    transition: all 0.2s;
    border: none;
    background: transparent;
    font-family: 'DM Mono', monospace;
  }
  .tab.active {
    background: var(--card);
    color: var(--text);
    border: 1px solid var(--border);
  }

  /* ── SECTION HEADER ── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
  }
  .section-title span { color: var(--muted); font-size: 0.8rem; font-family: 'DM Mono', monospace; font-weight: 400; margin-left: 0.5rem; }

  /* ── CARDS GRID ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* ── EMPLOYEE CARD ── */
  .employee-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.4rem;
    transition: all 0.2s;
    animation: fadeIn 0.3s ease;
  }
  .employee-card:hover { border-color: var(--employee); }

  .emp-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .emp-avatar {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--employee), #a855f7);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .emp-info { flex: 1; }
  .emp-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.95rem; }
  .emp-pos { color: var(--muted); font-size: 0.7rem; }

  .emp-stats {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }
  .stat {
    flex: 1;
    background: var(--surface);
    border-radius: 8px;
    padding: 0.6rem;
    text-align: center;
  }
  .stat-num { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--employee); }
  .stat-label { color: var(--muted); font-size: 0.62rem; }

  .emp-actions { display: flex; gap: 0.5rem; }

  /* ── LOG ENTRIES ── */
  .log-list { display: flex; flex-direction: column; gap: 0.8rem; }

  .log-entry {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.3rem;
    animation: slideUp 0.3s ease;
    transition: border-color 0.2s;
    position: relative;
    overflow: hidden;
  }
  .log-entry::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--employee);
    border-radius: 3px 0 0 3px;
  }
  .log-entry:hover { border-color: var(--border); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }

  .log-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.8rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .log-meta { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; }
  .log-emp {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--employee);
  }
  .log-client {
    font-size: 0.78rem;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    color: #c4b5fd;
  }
  .log-date { color: var(--muted); font-size: 0.7rem; }

  .log-topic {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .log-notes { color: #c8c8e0; font-size: 0.8rem; line-height: 1.6; }

  .log-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.8rem; }
  .tag {
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border-radius: 5px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  /* ── FORM CARD ── */
  .form-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    max-width: 600px;
  }

  /* ── STATS GRID ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    text-align: center;
  }
  .stat-card .big-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--accent);
  }
  .stat-card .big-num.emp { color: var(--employee); }
  .stat-card .big-num.green { color: var(--success); }
  .stat-card p { color: var(--muted); font-size: 0.72rem; margin-top: 0.2rem; }

  /* ── EMPTY STATE ── */
  .empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--muted);
  }
  .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
  .empty h3 { font-family: 'Syne', sans-serif; font-weight: 700; margin-bottom: 0.5rem; color: var(--text); }
  .empty p { font-size: 0.8rem; }

  /* ── FILTER BAR ── */
  .filter-bar {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .filter-bar input, .filter-bar select {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.9rem;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    outline: none;
  }
  .filter-bar input:focus, .filter-bar select:focus { border-color: var(--accent); }
  .filter-bar input { flex: 1; min-width: 200px; }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--success);
    color: #fff;
    padding: 0.8rem 1.4rem;
    border-radius: 10px;
    font-size: 0.82rem;
    font-family: 'DM Mono', monospace;
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s ease;
    z-index: 9999;
  }
  #toast.show { transform: translateY(0); opacity: 1; }

  /* ── MODAL ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1rem;
    animation: fadeIn 0.2s ease;
  }
  .modal {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
    max-width: 480px;
    width: 100%;
    animation: slideUp 0.3s ease;
  }
  .modal-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
  }
  .modal-actions { display: flex; gap: 0.8rem; margin-top: 1.5rem; justify-content: flex-end; }

  /* ── ANIMATIONS ── */
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* ── DIVIDER ── */
  .divider { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }

  /* ── ERROR ── */
  .error-msg {
    color: var(--danger);
    font-size: 0.72rem;
    margin-top: 0.4rem;
    display: none;
  }

  /* ── LOG DETAIL FULLSCREEN MODAL ── */
  #log-detail-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    padding: 1.5rem;
    animation: fadeIn 0.25s ease;
  }

  .log-detail-panel {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 24px;
    width: 100%;
    max-width: 760px;
    max-height: 92vh;
    overflow-y: auto;
    animation: slideUp 0.35s cubic-bezier(0.22,1,0.36,1);
    position: relative;
  }

  .log-detail-hero {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
    border-radius: 24px 24px 0 0;
    padding: 2.5rem 2.5rem 2rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .log-detail-hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 70%);
  }

  .log-detail-close {
    position: absolute;
    top: 1.2rem; right: 1.2rem;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 1rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
    z-index: 1;
  }
  .log-detail-close:hover { background: rgba(255,255,255,0.12); color: var(--text); }

  .log-detail-badge-row {
    display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.2rem;
  }

  .detail-badge {
    font-size: 0.68rem;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.5px;
  }
  .detail-badge.emp-badge {
    background: rgba(124,58,237,0.2);
    border: 1px solid rgba(124,58,237,0.4);
    color: #c4b5fd;
  }
  .detail-badge.result-pozytywny { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.35); color: #86efac; }
  .detail-badge.result-neutralny { background: rgba(148,163,184,0.12); border: 1px solid rgba(148,163,184,0.25); color: #cbd5e1; }
  .detail-badge.result-negatywny { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
  .detail-badge.result-do-kontaktu { background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.3); color: #93c5fd; }

  .log-detail-client {
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 0.4rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .log-detail-topic {
    font-family: 'Syne', sans-serif;
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -1px;
    margin-bottom: 0.8rem;
  }
  .log-detail-date {
    color: var(--muted);
    font-size: 0.73rem;
  }

  .log-detail-body { padding: 2rem 2.5rem 2.5rem; }

  .detail-section { margin-bottom: 2rem; }
  .detail-section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--muted);
    margin-bottom: 0.8rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .detail-section-content {
    font-size: 0.9rem;
    line-height: 1.8;
    color: #d0d0f0;
    white-space: pre-wrap;
  }

  .detail-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .detail-tag {
    font-size: 0.72rem;
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .detail-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .detail-info-item {
    background: var(--surface);
    border-radius: 10px;
    padding: 1rem;
  }
  .detail-info-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 0.4rem; }
  .detail-info-value { font-size: 0.88rem; color: var(--text); font-family: 'Syne', sans-serif; font-weight: 600; }

  /* ── CLICKABLE LOG ENTRY ── */
  .log-entry { cursor: pointer; }
  .log-entry:hover { border-color: var(--employee) !important; box-shadow: 0 4px 24px rgba(124,58,237,0.15); }
  .log-entry-hint {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    font-size: 0.67rem;
    margin-top: 0.7rem;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .log-entry:hover .log-entry-hint { opacity: 1; }

  /* ── PROFILE PHOTO ── */
  .avatar-upload-wrap {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.5rem;
  }
  .avatar-preview {
    width: 80px;
    height: 80px;
    border-radius: 16px;
    object-fit: cover;
    border: 2px solid var(--border);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    overflow: hidden;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .avatar-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 14px;
  }
  .avatar-upload-info { flex: 1; }
  .avatar-upload-info p { color: var(--muted); font-size: 0.72rem; line-height: 1.6; margin-top: 0.3rem; }
  .avatar-file-input { display: none; }
  .avatar-upload-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px dashed var(--border);
    background: var(--surface);
    color: var(--muted);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Mono', monospace;
  }
  .avatar-upload-btn:hover { border-color: var(--accent); color: var(--accent); }
  .avatar-remove-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Mono', monospace;
    margin-top: 0.4rem;
  }
  .avatar-remove-btn:hover { border-color: var(--danger); color: var(--danger); }

  /* ── TOPBAR AVATAR ── */
  .topbar-avatar {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .topbar-avatar-placeholder {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    font-family: 'Syne', sans-serif;
    flex-shrink: 0;
  }

  /* ── EMP AVATAR WITH PHOTO ── */
  .emp-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
  }

  /* ── SETTINGS ── */
  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
    max-width: 800px;
  }
  .settings-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.8rem;
  }
  .settings-card-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }
  .settings-card-desc {
    color: var(--muted);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  /* ── PASSWORD INPUT WITH TOGGLE ── */
  .pass-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .pass-input-wrap input {
    padding-right: 2.8rem;
  }
  .pass-toggle {
    position: absolute;
    right: 0.6rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0.3rem;
    color: var(--muted);
    transition: color 0.2s;
    line-height: 1;
  }
  .pass-toggle:hover { color: var(--text); }

  /* ── EMPLOYEE CARD PASSWORD ROW ── */
  .emp-pass-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.8rem;
    margin-bottom: 0.8rem;
    font-size: 0.75rem;
  }
  .emp-pass-label { color: var(--muted); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; flex-shrink: 0; }
  .emp-pass-value { font-family: 'DM Mono', monospace; flex: 1; letter-spacing: 2px; }
  .emp-pass-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    font-size: 0.8rem;
    padding: 0;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .emp-pass-toggle:hover { color: var(--accent); }

  /* ── CLIENT CARD ── */
  .client-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.4rem;
    transition: all 0.2s;
    animation: fadeIn 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .client-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    border-radius: 3px 0 0 3px;
  }
  .client-card:hover { border-color: var(--accent); }
  .client-card-header { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.8rem; }
  .client-avatar {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent), #ff9a6c);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; flex-shrink: 0;
  }
  .client-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.95rem; }
  .client-industry { color: var(--muted); font-size: 0.7rem; }
  .client-notes-preview { color: var(--muted); font-size: 0.75rem; line-height: 1.5; margin-bottom: 0.8rem; }
  .client-stats { display: flex; gap: 0.6rem; margin-bottom: 0.8rem; }
  .client-stat {
    flex: 1; background: var(--surface); border-radius: 7px;
    padding: 0.5rem; text-align: center;
  }
  .client-stat-num { font-family: 'Syne', sans-serif; font-weight: 700; color: var(--accent); font-size: 1rem; }
  .client-stat-label { color: var(--muted); font-size: 0.6rem; }

  /* ── USER DROPDOWN ── */
  .user-badge-wrap {
    position: relative;
  }
  .user-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    user-select: none;
  }
  .user-badge:hover, .user-badge-wrap:hover .user-badge { border-color: var(--accent); background: var(--surface); }

  .user-dropdown {
    position: absolute;
    top: calc(100% + 2px);
    right: 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    min-width: 220px;
    padding: 0.5rem;
    z-index: 500;
    box-shadow: 0 16px 40px rgba(0,0,0,0.5);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  /* invisible bridge so mouse can travel from badge to dropdown without gap */
  .user-badge-wrap::after {
    content: '';
    position: absolute;
    top: 100%;
    right: 0;
    width: 100%;
    height: 12px;
  }
  .user-badge-wrap:hover .user-dropdown {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0);
  }
  .user-dropdown-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.6rem 0.6rem 0.8rem;
  }
  .user-dropdown-divider {
    height: 1px;
    background: var(--border);
    margin: 0.3rem 0;
  }
  .user-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.55rem 0.8rem;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.15s;
    text-align: left;
  }
  .user-dropdown-item:hover { background: var(--surface); }
  .user-dropdown-item.danger { color: var(--danger); }
  .user-dropdown-item.danger:hover { background: rgba(239,68,68,0.1); }

  /* ── CHAT TOPBAR BTN ── */
  .chat-topbar-btn {
    position: relative;
    width: 36px; height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--card);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .chat-topbar-btn:hover { border-color: var(--accent); background: var(--surface); }
  .chat-unread-badge {
    position: absolute;
    top: -5px; right: -5px;
    background: var(--accent);
    color: #fff;
    border-radius: 10px;
    font-size: 0.6rem;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    padding: 0 0.3rem;
    min-width: 16px;
    text-align: center;
    line-height: 16px;
    height: 16px;
  }

  /* ── CHAT PANEL (SLIDE-IN) ── */
  #chat-panel {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 380px;
    max-width: 100vw;
    background: var(--card);
    border-left: 1px solid var(--border);
    z-index: 800;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
    box-shadow: -8px 0 32px rgba(0,0,0,0.4);
  }
  #chat-panel.open { transform: translateX(0); }

  #chat-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 799;
    display: none;
    backdrop-filter: blur(2px);
  }
  #chat-backdrop.open { display: block; }

  .chat-panel-header {
    padding: 1.2rem 1.4rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .chat-panel-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; }
  .chat-close-btn {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .chat-close-btn:hover { color: var(--text); border-color: var(--muted); }

  /* Conversation list (employer view) */
  .chat-conv-list { flex: 1; overflow-y: auto; padding: 0.8rem; }
  .chat-conv-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.15s;
    position: relative;
  }
  .chat-conv-item:hover { background: var(--surface); }
  .chat-conv-item.active { background: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.25); }
  .chat-conv-avatar {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--employee), #a855f7);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem;
    flex-shrink: 0; overflow: hidden;
  }
  .chat-conv-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; }
  .chat-conv-info { flex: 1; min-width: 0; }
  .chat-conv-name { font-family: 'Syne', sans-serif; font-weight: 600; font-size: 0.85rem; }
  .chat-conv-preview { color: var(--muted); font-size: 0.7rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 0.1rem; }
  .chat-conv-meta { text-align: right; flex-shrink: 0; }
  .chat-conv-time { color: var(--muted); font-size: 0.65rem; }
  .chat-conv-unread {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    border-radius: 10px;
    font-size: 0.6rem;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    min-width: 18px;
    text-align: center;
    margin-top: 0.2rem;
  }

  /* Chat window */
  .chat-window { flex: 1; display: flex; flex-direction: column; min-height: 0; }
  .chat-window-header {
    padding: 1rem 1.2rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-shrink: 0;
  }
  .chat-back-btn {
    background: none; border: none; color: var(--muted);
    cursor: pointer; font-size: 1.1rem; padding: 0;
    transition: color 0.2s;
  }
  .chat-back-btn:hover { color: var(--text); }
  .chat-window-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem; }
  .chat-window-sub { color: var(--muted); font-size: 0.68rem; }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    scroll-behavior: smooth;
  }
  .chat-msg {
    max-width: 78%;
    padding: 0.65rem 0.9rem;
    border-radius: 14px;
    font-size: 0.8rem;
    line-height: 1.5;
    position: relative;
    word-break: break-word;
  }
  .chat-msg.sent {
    background: var(--employee);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .chat-msg.received {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-msg.sent.employer-msg { background: var(--accent); }
  .chat-msg-time { font-size: 0.6rem; opacity: 0.65; margin-top: 0.3rem; display: block; }
  .chat-msg.sent .chat-msg-time { text-align: right; }

  .chat-date-sep {
    text-align: center;
    font-size: 0.65rem;
    color: var(--muted);
    margin: 0.5rem 0;
    position: relative;
  }
  .chat-date-sep::before {
    content: '';
    position: absolute;
    top: 50%; left: 0; right: 0;
    height: 1px;
    background: var(--border);
    z-index: 0;
  }
  .chat-date-sep span {
    background: var(--card);
    padding: 0 0.8rem;
    position: relative;
    z-index: 1;
  }

  .chat-input-area {
    padding: 0.8rem 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 0.6rem;
    align-items: flex-end;
    flex-shrink: 0;
  }
  .chat-input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.6rem 0.9rem;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    outline: none;
    resize: none;
    max-height: 100px;
    transition: border-color 0.2s;
  }
  .chat-input:focus { border-color: var(--employee); }
  .chat-send-btn {
    width: 38px; height: 38px;
    border-radius: 10px;
    background: var(--employee);
    border: none;
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    transition: background 0.2s, transform 0.1s;
    flex-shrink: 0;
  }
  .chat-send-btn:hover { background: #9d5df0; transform: scale(1.05); }
  .chat-send-btn.employer { background: var(--accent); }
  .chat-send-btn.employer:hover { background: #ff8055; }

  .chat-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    padding: 2rem;
    text-align: center;
  }
  .chat-empty-icon { font-size: 2.5rem; margin-bottom: 0.8rem; }
  .chat-empty h3 { font-family: 'Syne', sans-serif; font-weight: 700; margin-bottom: 0.4rem; color: var(--text); font-size: 0.95rem; }
  .chat-empty p { font-size: 0.75rem; }

  /* ── SETTINGS MODAL PANEL ── */
  #settings-panel {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 520px;
    max-width: 100vw;
    background: var(--card);
    border-left: 1px solid var(--border);
    z-index: 800;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
    box-shadow: -8px 0 32px rgba(0,0,0,0.4);
    overflow-y: auto;
  }
  #settings-panel.open { transform: translateX(0); }
  #settings-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 799;
    display: none;
    backdrop-filter: blur(2px);
  }
  #settings-backdrop.open { display: block; }
  .settings-panel-header {
    padding: 1.4rem 1.6rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    background: var(--card);
    z-index: 10;
  }
  .settings-panel-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem; }
  .settings-panel-body { padding: 1.6rem; display: flex; flex-direction: column; gap: 1.4rem; }

  /* ── ACTIVE FILTER CHIP ── */
  .filter-chip {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(255,107,53,0.12);
    border: 1px solid rgba(255,107,53,0.3);
    color: var(--accent);
    font-size: 0.7rem;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    .role-cards { grid-template-columns: 1fr; }
    .topbar { padding: 0.8rem 1rem; }
    .main-content { padding: 1rem; }
    .topbar-logo { font-size: 1rem; }
    .log-detail-hero { padding: 1.5rem 1.2rem 1.2rem; }
    .log-detail-body { padding: 1.2rem; }
    .log-detail-topic { font-size: 1.4rem; }
    .detail-info-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- TOAST -->
<div id="toast"></div>

<!-- LOGIN SCREEN -->
<div id="login-screen">
  <div class="login-logo">Work<span>Log</span></div>
  <div class="login-sub">System zarządzania rozmowami</div>

  <!-- Role selection -->
  <div id="role-select" class="role-cards">
    <div class="role-card" onclick="showLogin('employer')">
      <div class="role-icon">👔</div>
      <div class="role-title">Pracodawca</div>
      <div class="role-desc">Zarządzaj pracownikami, przeglądaj wszystkie raporty i statystyki.</div>
    </div>
    <div class="role-card employee" onclick="showLogin('employee')">
      <div class="role-icon">💼</div>
      <div class="role-title">Pracownik</div>
      <div class="role-desc">Dodawaj wpisy o rozmowach z klientami.</div>
    </div>
  </div>

  <!-- Employer login -->
  <div id="employer-login" class="login-form" style="display:none;">
    <div class="form-title">👔 Logowanie pracodawcy</div>
    <div class="form-subtitle">Wprowadź dane dostępowe administratora</div>
    <div class="field">
      <label>Login</label>
      <input type="text" id="emp-login" placeholder="admin" />
    </div>
    <div class="field">
      <label>Hasło</label>
      <input type="password" id="emp-pass" placeholder="••••••" />
      <div class="error-msg" id="emp-err">Nieprawidłowe dane logowania</div>
    </div>
    <button class="btn btn-primary btn-full" onclick="loginEmployer()">Zaloguj się →</button>
    <a class="back-link" onclick="showForgotCredentials()" style="color:var(--accent);margin-top:0.6rem;">🔑 Zapomniałem loginu / hasła</a>
    <a class="back-link" onclick="showRoleSelect()">← Wróć do wyboru roli</a>
  </div>

  <!-- Employee login -->
  <div id="employee-login" class="login-form" style="display:none;">
    <div class="form-title">💼 Logowanie pracownika</div>
    <div class="form-subtitle">Wybierz swoje konto</div>
    <div class="field">
      <label>Wybierz pracownika</label>
      <select id="emp-select">
        <option value="">-- wybierz --</option>
      </select>
    </div>
    <div class="field">
      <label>Hasło</label>
      <input type="password" id="emp-worker-pass" placeholder="••••••" />
      <div class="error-msg" id="emp-worker-err">Nieprawidłowe hasło</div>
    </div>
    <button class="btn btn-secondary btn-full" onclick="loginEmployee()">Zaloguj się →</button>
    <a class="back-link" onclick="showRoleSelect()">← Wróć do wyboru roli</a>
  </div>
</div>

<!-- FORGOT CREDENTIALS MODAL -->
<div id="forgot-modal" class="modal-overlay" style="display:none;">
  <div class="modal" style="max-width:440px;">
    <div class="modal-title">🔑 Resetuj dane logowania</div>
    <p style="color:var(--muted);font-size:0.78rem;margin-bottom:1.4rem;line-height:1.6;">Ustaw nowy login i/lub hasło do konta pracodawcy. Pola które zostawisz puste nie zostaną zmienione.</p>

    <div class="field">
      <label>Nowy login <span style="color:var(--muted);font-weight:400;">(zostaw puste = bez zmian)</span></label>
      <input type="text" id="forgot-new-login" placeholder="min. 3 znaki" />
    </div>
    <div class="field">
      <label>Nowe hasło <span style="color:var(--muted);font-weight:400;">(zostaw puste = bez zmian)</span></label>
      <div class="pass-input-wrap">
        <input type="password" id="forgot-new-pass" placeholder="min. 4 znaki" />
        <button class="pass-toggle" onclick="togglePass('forgot-new-pass', this)">👁</button>
      </div>
    </div>
    <div class="field">
      <label>Powtórz nowe hasło</label>
      <div class="pass-input-wrap">
        <input type="password" id="forgot-new-pass2" placeholder="••••••" />
        <button class="pass-toggle" onclick="togglePass('forgot-new-pass2', this)">👁</button>
      </div>
    </div>

