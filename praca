function switchTab(tab) {
  ['overview','employees','clients','logs'].forEach(t => {
    document.getElementById('tab-' + t).style.display = t === tab ? 'block' : 'none';
  });
  document.querySelectorAll('#employer-view .tab').forEach((el, i) => {
    el.classList.toggle('active', ['overview','employees','clients','logs'][i] === tab);
  });
  if (tab === 'overview') renderOverview();
  if (tab === 'employees') renderEmployees();
  if (tab === 'clients') renderClients();
  if (tab === 'logs') { renderAllLogs(); populateFilterSelect(); populateClientFilterSelect(); }
}

function switchEmpTab(tab) {
  ['add','my-logs'].forEach(t => {
    document.getElementById('etab-' + t).style.display = t === tab ? 'block' : 'none';
  });
  document.querySelectorAll('#employee-view .tab').forEach((el, i) => {
    el.classList.toggle('active', ['add','my-logs'][i] === tab);
