function addLog() {
  const selVal = document.getElementById('log-client-select').value;
  let client = '';
  if (selVal === '__manual__') {
    client = document.getElementById('log-client-manual').value.trim();
  } else {
    client = selVal;
  }
  const topic = document.getElementById('log-topic').value.trim();
  const notes = document.getElementById('log-notes').value.trim();
  const result = document.getElementById('log-result').value;
  const tagsRaw = document.getElementById('log-tags').value.trim();

  if (!client || !topic) { toast('Klient i temat są wymagane', 'error'); return; }

  const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : [];
  const { logs } = loadState();
  logs.unshift({
    id: 'log_' + Date.now(),
    employeeId: currentUser.id,
    employeeName: currentUser.name,
    client,
    topic,
    notes,
    result,
    tags,
    createdAt: new Date().toISOString()
  });
  saveLogs(logs);
  // Reset
  document.getElementById('log-client-select').value = '';
  document.getElementById('log-client-manual').value = '';
  document.getElementById('log-client-manual-field').style.display = 'none';
  document.getElementById('log-topic').value = '';
  document.getElementById('log-notes').value = '';
  document.getElementById('log-tags').value = '';
  document.getElementById('log-result').value = 'pozytywny';
  toast('Wpis zapisany!');
  renderMyLogs();
}

function renderMyLogs() {
  const { logs } = loadState();
  const myLogs = logs.filter(l => l.employeeId === currentUser.id);
  const container = document.getElementById('my-logs');
  if (!myLogs.length) {
    container.innerHTML = `<div class="empty"><div class="empty-icon">📋</div><h3>Brak wpisów</h3><p>Dodaj swój pierwszy wpis rozmowy.</p></div>`;
    return;
  }
  container.innerHTML = myLogs.map(l => logHTML(l)).join('');
}

